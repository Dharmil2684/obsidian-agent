# Copy this to .env and fill in your values
# (The real .env is git-ignored — never commit secrets)

# Absolute path to your Obsidian vault folder
VAULT_PATH=C:\Users\YourName\Documents\YourVault

# Ollama model name (must be pulled: ollama pull hermes3)
LOCAL_MODEL=hermes3

# Groq API key — free tier: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Ollama server (default — change if you run Ollama on a different port)
OLLAMA_BASE_URL=http://localhost:11434

# FastAPI port
API_PORT=8000

# Number of backup copies to keep per vault file
MAX_BACKUPS=3
